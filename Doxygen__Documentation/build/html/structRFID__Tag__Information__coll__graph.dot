digraph "RFID_Tag_Information"
{
 // LATEX_PDF_SIZE
  edge [fontname="Helvetica",fontsize="12",labelfontname="Helvetica",labelfontsize="12"];
  node [fontname="Helvetica",fontsize="12",shape=record];
  Node1 [label="{RFID_Tag_Information\n||}",height=0.2,width=0.4,color="black", fillcolor="grey75", style="filled", fontcolor="black",tooltip=" "];
  Node2 -> Node1 [color="grey25",fontsize="12",style="solid",label=" +room_description\n+room_name" ,arrowhead="odiamond",fontname="Helvetica"];
  Node2 [label="{char\n||}",height=0.2,width=0.4,color="grey75", fillcolor="white", style="filled",tooltip=" "];
  Node3 -> Node1 [color="grey25",fontsize="12",style="solid",label=" +destination_node" ,arrowhead="odiamond",fontname="Helvetica"];
  Node3 [label="{bool\n||}",height=0.2,width=0.4,color="grey75", fillcolor="white", style="filled",tooltip=" "];
}
